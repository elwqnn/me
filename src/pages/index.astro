---
import { getCollection } from "astro:content"
import Layout from "@/layouts/main.astro"
import { ThemeToggle } from "@/components/ThemeToggle"
import { ProjectShowcase } from "@/components/ProjectShowcase"
import { ExternalLinkIcon } from "@/components/icons"

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
)
---

<Layout>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-3xl px-6 py-12 sm:py-20 md:py-16">
      <header class="mb-12 flex w-full items-start justify-between">
        <div class="flex flex-col">
          <a
            href="/"
            class="text-sm font-medium transition-colors duration-200 hover:text-primary"
          >
            Elwann Guillemot
          </a>
          <span class="text-sm text-muted-foreground">Back-end Developer</span>
        </div>
        <ThemeToggle client:load />
      </header>

      <section class="py-12">
        <h3 class="mb-6 text-lg font-medium">Today</h3>
        <p class="text-muted-foreground">
          I am currently in my fourth year studying abroad at the <a
            href="https://www.hanze.nl/en"
            class="underline decoration-muted-foreground/50 underline-offset-2 transition-colors duration-200 hover:text-primary hover:decoration-primary"
            target="_blank"
            rel="noopener noreferrer">Hanze University of Applied Sciences</a
          > in Groningen, the Netherlands. I enjoy building any kind of tool that
          makes life easier. I care about{" "}
          <span class="text-foreground">performance</span> and{" "}
          <span class="text-foreground">user experience</span>.
        </p>
      </section>

      <section id="projects" class="py-12">
        <h3 class="mb-6 text-lg font-medium">Some of my Projects</h3>
        <ProjectShowcase
          projects={projects.map((p) => ({
            slug: p.slug,
            title: p.data.title,
            description: p.data.description,
            tags: p.data.tags,
            images: p.data.images,
            accentColor: p.data.accentColor ?? "var(--primary)",
            year: p.data.year,
          }))}
          client:load
        />
      </section>

      <section class="py-12">
        <h3 class="mb-6 text-lg font-medium">Contact</h3>
        <p class="mb-4 text-muted-foreground">
          Feel free to reach out if you're looking to collaborate on a project,
          have a job opportunity, or just want to connect.
        </p>
        <a
          href="mailto:elwann.guillemot@epitech.eu"
          class="inline-flex items-center gap-1.5 font-medium transition-colors duration-200 hover:text-primary"
        >
          elwann.guillemot@epitech.eu
          <ExternalLinkIcon size={16} />
        </a>
      </section>

      <section class="py-12">
        <h3 class="mb-6 text-lg font-medium">More</h3>
        <p class="text-muted-foreground">
          You can see more of my work on my <a
            href="https://github.com/Elwqnn"
            class="inline underline decoration-muted-foreground/50 underline-offset-2 transition-colors duration-200 hover:text-primary hover:decoration-primary"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          > or check out my <a
            href="/documents/elwann_guillemot_resume.pdf"
            class="inline underline decoration-muted-foreground/50 underline-offset-2 transition-colors duration-200 hover:text-primary hover:decoration-primary"
            >resume</a
          >.
        </p>
      </section>
    </div>
  </div>
</Layout>
